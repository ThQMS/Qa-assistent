# Copie este arquivo para ".env" (nesta mesma pasta backend/) e preencha:
#   cp .env.example .env

# Obrigatório: sua chave da Groq — crie grátis em https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Porta do servidor local (http://localhost:3001)
PORT=3001

NODE_ENV=production

# Opcional: modelo da Groq a usar (padrão: llama-3.3-70b-versatile).
# Troque se a cota diária do modelo padrão estourar.
# GROQ_MODEL=llama-3.3-70b-versatile
